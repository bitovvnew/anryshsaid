<Window x:Class="SAIL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SAIL.Views"
        Title="SAIL PROJECT — SAIL Launcher"
        Height="820" Width="1220"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="12" Background="{StaticResource BgDeepBrush}"
            BorderBrush="#28FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="#18FFFFFF"
                    BorderBrush="#12FFFFFF" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/app-icon.png"
                               Width="28" Height="28" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SAIL PROJECT" FontFamily="{StaticResource AppFont}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" 🇷🇺 🇺🇸" FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="SAIL Launcher" FontFamily="{StaticResource AppFont}"
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Border Background="#220078D4" CornerRadius="6" Padding="8,3" Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="VersionBadge" Text="bito 0.0.0.1"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10" Foreground="{StaticResource AccentBlueBrush}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource TitleBarButton}" Content="&#xE921;"
                                Click="Minimize_Click" ToolTip="Свернуть"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="&#xE922;"
                                Click="Maximize_Click" ToolTip="Развернуть"/>
                        <Button Style="{StaticResource CloseButton}" Content="&#xE8BB;"
                                Click="Close_Click" ToolTip="Закрыть"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main layout -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="252"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                        BorderBrush="#12FFFFFF" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" MaxHeight="420">
                        <StackPanel Margin="8,20,8,16">
                            <TextBlock Text="НАВИГАЦИЯ" FontFamily="{StaticResource AppFont}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="16,0,0,8"/>
                            <RadioButton x:Name="NavHome" Style="{StaticResource NavButton}"
                                         Content="Главная" GroupName="Nav">
                                <RadioButton.Tag>
                                    <TextBlock Text="🏠" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                            <RadioButton x:Name="NavContract" Style="{StaticResource NavButton}"
                                         Content="Договор 15%" GroupName="Nav">
                                <RadioButton.Tag>
                                    <TextBlock Text="📜" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                            <RadioButton x:Name="NavGallery" Style="{StaticResource NavButton}"
                                         Content="Мега-мемы" GroupName="Nav">
                                <RadioButton.Tag>
                                    <TextBlock Text="🤣" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                            <RadioButton x:Name="NavFun" Style="{StaticResource NavButton}"
                                         Content="Зона приколов" GroupName="Nav">
                                <RadioButton.Tag>
                                    <TextBlock Text="🎪" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                            <RadioButton x:Name="NavMines" Style="{StaticResource NavButton}"
                                         Content="Сапёр" GroupName="Nav">
                                <RadioButton.Tag>
                                    <TextBlock Text="💣" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                        </StackPanel>
                        </ScrollViewer>

                        <!-- Launch button + подпись -->
                        <StackPanel Grid.Row="2" Margin="16,0,16,20">
                            <Button Content="📋 Соглашение" Style="{StaticResource SecondaryButton}"
                                    Click="Agreement_Click" Margin="0,0,0,12"/>
                            <Button Content="🚀 Запустить SAIL" Style="{StaticResource PrimaryButton}"
                                    Click="Launch_Click" Margin="0,0,0,12"/>
                            <TextBlock Text="🇷🇺 Русский  ·  🇺🇸 English"
                                       FontFamily="{StaticResource AppFont}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Центр продажи Roblox-аккаунтов"
                                       FontFamily="{StaticResource AppFont}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <Border Background="#10FFFFFF" CornerRadius="8" Padding="10,8" Margin="0,0,0,10">
                                <StackPanel>
                                    <CheckBox x:Name="SoundToggle" Content="🔊 Звуки SAIL"
                                              IsChecked="True" Checked="SoundToggle_Changed"
                                              Unchecked="SoundToggle_Changed"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              FontFamily="{StaticResource AppFont}" FontSize="11"/>
                                    <CheckBox x:Name="RandomSoundToggle" Content="🎲 Рандом звуки"
                                              IsChecked="True" Checked="RandomSoundToggle_Changed"
                                              Unchecked="RandomSoundToggle_Changed"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              FontFamily="{StaticResource AppFont}" FontSize="11"
                                              Margin="0,6,0,0"/>
                                    <TextBlock Text="XP startup · добрые · хоррор · сюрпризы"
                                               FontFamily="{StaticResource AppFont}" FontSize="9"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="24,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#10FFFFFF" CornerRadius="8" Padding="10,8">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔏 Цифровая подпись" FontFamily="{StaticResource AppFont}"
                                               FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="dolbaeb productions" FontFamily="{StaticResource AppFont}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    <TextBlock Text="bito 0.0.0.1" FontFamily="{StaticResource AppFont}"
                                               FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <Grid Grid.Column="1" Background="{StaticResource BgSurfaceBrush}">
                    <!-- Ambient glow -->
                    <Ellipse Width="400" Height="400" HorizontalAlignment="Right"
                             VerticalAlignment="Top" Margin="0,-100,-100,0"
                             Fill="#080078D4" IsHitTestVisible="False"/>
                    <Ellipse Width="300" Height="300" HorizontalAlignment="Left"
                             VerticalAlignment="Bottom" Margin="-80,0,0,-80"
                             Fill="#08FF375F" IsHitTestVisible="False"/>

                    <ContentControl x:Name="ContentHost" Margin="32,24,32,24"/>
                </Grid>
            </Grid>

            <!-- Meme overlay (iOS 26 alert style) -->
            <Border x:Name="MemeOverlay" Grid.RowSpan="2" Visibility="Collapsed"
                    Background="#CC000000" Panel.ZIndex="1000">
                <Border Style="{StaticResource GlassCard}" MaxWidth="480" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Padding="32" Margin="40"
                        BorderBrush="{StaticResource AccentPinkBrush}" BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="🚨" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="MemeOverlayTitle" Text="ЭТО НЕ ВЫХОД"
                                   FontFamily="{StaticResource AppFont}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentPinkBrush}"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,12,0,8"/>
                        <TextBlock x:Name="MemeOverlayText" Text=""
                                   FontFamily="{StaticResource AppFont}" FontSize="15"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center" LineHeight="24"/>
                        <Button Content="😤 Убрать мем" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Center" Margin="0,24,0,0"
                                Click="DismissMeme_Click"/>
                        <TextBlock Text="Исчезнет через 5 сек · iOS 26 style"
                                   FontFamily="{StaticResource AppFont}" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
