<Window x:Class="SAIL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SAIL.Views"
        Title="SAIL PROJECT — SAIL Launcher"
        Height="780" Width="1180"
        MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="12" Background="{StaticResource BgDeepBrush}"
            BorderBrush="#28FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="#18FFFFFF"
                    BorderBrush="#12FFFFFF" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/app-icon.png"
                               Width="28" Height="28" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="SAIL PROJECT" FontFamily="{StaticResource AppFont}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text=" 🇷🇺 🇺🇸" FontSize="13" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="SAIL Launcher" FontFamily="{StaticResource AppFont}"
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Border Background="#220078D4" CornerRadius="6" Padding="8,3" Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="VersionBadge" Text="bito 0.0.0.1"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="10" Foreground="{StaticResource AccentBlueBrush}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource TitleBarButton}" Content="&#xE921;"
                                Click="Minimize_Click" ToolTip="Свернуть"/>
                        <Button Style="{StaticResource TitleBarButton}" Content="&#xE922;"
                                Click="Maximize_Click" ToolTip="Развернуть"/>
                        <Button Style="{StaticResource CloseButton}" Content="&#xE8BB;"
                                Click="Close_Click" ToolTip="Закрыть"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main layout -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                        BorderBrush="#12FFFFFF" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="8,20,8,16">
                            <TextBlock Text="НАВИГАЦИЯ" FontFamily="{StaticResource AppFont}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="16,0,0,8"/>
                            <RadioButton x:Name="NavHome" Style="{StaticResource NavButton}"
                                         Content="Главная" GroupName="Nav" IsChecked="True"
                                         Checked="Nav_Checked">
                                <RadioButton.Tag>
                                    <TextBlock Text="🏠" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                            <RadioButton x:Name="NavContract" Style="{StaticResource NavButton}"
                                         Content="Договор 15%" GroupName="Nav"
                                         Checked="Nav_Checked">
                                <RadioButton.Tag>
                                    <TextBlock Text="📜" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                            <RadioButton x:Name="NavGallery" Style="{StaticResource NavButton}"
                                         Content="Мемы" GroupName="Nav"
                                         Checked="Nav_Checked">
                                <RadioButton.Tag>
                                    <TextBlock Text="🤣" FontSize="16"/>
                                </RadioButton.Tag>
                            </RadioButton>
                        </StackPanel>

                        <!-- Launch button + подпись -->
                        <StackPanel Grid.Row="2" Margin="16,0,16,20">
                            <Button Content="🚀 Запустить SAIL" Style="{StaticResource PrimaryButton}"
                                    Click="Launch_Click" Margin="0,0,0,12"/>
                            <TextBlock Text="🇷🇺 Русский  ·  🇺🇸 English"
                                       FontFamily="{StaticResource AppFont}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Центр продажи Roblox-аккаунтов"
                                       FontFamily="{StaticResource AppFont}" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <Border Background="#10FFFFFF" CornerRadius="8" Padding="10,8">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="🔏 Цифровая подпись" FontFamily="{StaticResource AppFont}"
                                               FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="dolbaeb productions" FontFamily="{StaticResource AppFont}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentPurpleBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    <TextBlock Text="bito 0.0.0.1" FontFamily="{StaticResource AppFont}"
                                               FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content -->
                <Grid Grid.Column="1" Background="{StaticResource BgSurfaceBrush}">
                    <!-- Ambient glow -->
                    <Ellipse Width="400" Height="400" HorizontalAlignment="Right"
                             VerticalAlignment="Top" Margin="0,-100,-100,0"
                             Fill="#080078D4" IsHitTestVisible="False"/>
                    <Ellipse Width="300" Height="300" HorizontalAlignment="Left"
                             VerticalAlignment="Bottom" Margin="-80,0,0,-80"
                             Fill="#08FF375F" IsHitTestVisible="False"/>

                    <ContentControl x:Name="ContentHost" Margin="32,24,32,24"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
