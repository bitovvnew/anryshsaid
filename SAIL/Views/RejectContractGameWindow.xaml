<Window x:Class="SAIL.Views.RejectContractGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SAIL — Побег от 15%"
        Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border CornerRadius="20" Background="{StaticResource BgDeepBrush}"
            BorderBrush="#28FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="🏃 Побег от 15%" FontFamily="{StaticResource AppFont}"
                           FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Жми «СВОБОДА», избегай «15%». 12 попаданий за 20 сек!"
                           FontFamily="{StaticResource AppFont}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="16">
                <Grid>
                    <Canvas x:Name="GameCanvas" Background="#08FFFFFF" ClipToBounds="True"
                            Height="280" MinWidth="360"/>
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,8,0,0">
                        <TextBlock x:Name="ScoreText" Text="✨ 0 / 12" FontFamily="{StaticResource AppFont}"
                                   FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TimeText" Text="⏱ 20" FontFamily="{StaticResource AppFont}"
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Сдаться" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,12,0" Click="GiveUp_Click"/>
                <Button Content="✕" Style="{StaticResource CloseButton}" Click="GiveUp_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
