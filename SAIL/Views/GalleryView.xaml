<UserControl x:Class="SAIL.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="🤣 Мега-галерея мемов" FontFamily="{StaticResource AppFont}"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="10+ ассетов · Roblox · 15% · dolbaeb productions · 🇷🇺 🇺🇸"
                           FontFamily="{StaticResource AppFont}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
            </StackPanel>

            <ItemsControl x:Name="MemeItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,10,16">
                            <StackPanel>
                                <Border CornerRadius="12" ClipToBounds="True" Height="200">
                                    <Image Source="{Binding ImageUri}" Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding Title}" FontFamily="{StaticResource AppFont}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,12,0,4"/>
                                <TextBlock Text="{Binding Caption}" FontFamily="{StaticResource AppFont}"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <Button Content="{Binding ButtonText}" Style="{StaticResource SecondaryButton}"
                                        Margin="0,12,0,0" HorizontalAlignment="Left"
                                        Click="Laugh_Click" Tag="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource GlassCard}" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="🧮 Калькулятор 15%" FontFamily="{StaticResource AppFont}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Цена продажи (₽)" FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="PriceInput" Margin="0,8,0,0"
                                     Background="#12FFFFFF" Foreground="White"
                                     BorderBrush="#28FFFFFF" BorderThickness="1"
                                     Padding="12,10" FontFamily="{StaticResource AppFont}"
                                     FontSize="16" CaretBrush="White" Text="1000"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="→" FontSize="24"
                                   VerticalAlignment="Bottom" Margin="20,0,20,10"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Друг получает (15%)" FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="ResultText" Text="150 ₽" FontFamily="{StaticResource AppFont}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGreenBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button Content="Посчитать боль" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,16,0,0"
                            Click="Calculate_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
