<Window x:Class="SAIL.Views.UserAgreementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SAIL PROJECT — Пользовательское соглашение"
        Height="640" Width="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True">

    <Border CornerRadius="16" Background="{StaticResource BgDeepBrush}"
            BorderBrush="#28FFFFFF" BorderThickness="1" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.7" Color="Black"/>
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Padding="28,24,28,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.35">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#8860D0" Offset="0.5"/>
                        <GradientStop Color="#FF375F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Пользовательское соглашение" FontFamily="{StaticResource AppFont}"
                                       FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="SAIL PROJECT · bito 0.0.0.1 · 🇷🇺 🇺🇸" FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="#D0FFFFFF" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Перед использованием SAIL Launcher необходимо принять условия"
                               FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="#B0FFFFFF" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,20">
                <StackPanel>
                    <Border Style="{StaticResource GlassCard}" Padding="20">
                        <TextBlock x:Name="AgreementText" FontFamily="{StaticResource AppFont}"
                                   FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" LineHeight="24"/>
                    </Border>

                    <CheckBox x:Name="AgreeTerms" Margin="0,20,0,8"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource AppFont}" FontSize="13">
                        Я прочитал(а) и принимаю пользовательское соглашение
                    </CheckBox>
                    <CheckBox x:Name="AgreeAge" Margin="0,0,0,8"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource AppFont}" FontSize="13">
                        Мне исполнилось 18 лет (или есть согласие родителей)
                    </CheckBox>
                    <CheckBox x:Name="AgreePrivacy"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource AppFont}" FontSize="13">
                        Я согласен(на) с политикой конфиденциальности
                    </CheckBox>

                    <TextBlock Text="🔏 dolbaeb productions · Цифровая подпись ПО"
                               FontFamily="{StaticResource AppFont}" FontSize="11"
                               Foreground="{StaticResource AccentPurpleBrush}"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#12FFFFFF" BorderBrush="#18FFFFFF"
                    BorderThickness="0,1,0,0" Padding="28,16" CornerRadius="0,0,16,16">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="Без принятия соглашения программа закроется"
                                   FontFamily="{StaticResource AppFont}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DeclineButton" Content="Отклонить" Style="{StaticResource SecondaryButton}"
                                Margin="0,0,12,0" Click="Decline_Click" Width="120"/>
                        <Button x:Name="AcceptButton" Content="✅ Принимаю" Style="{StaticResource PrimaryButton}"
                                Click="Accept_Click" Width="140" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
