<UserControl x:Class="SAIL.Views.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📜 Договор между двумя людьми" FontFamily="{StaticResource AppFont}"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="О добровольном (нет) отчислении 15% с продажи аккаунта Roblox"
                       FontFamily="{StaticResource AppFont}" FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Contract body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource GlassCard}" Background="#FF1A1A24">
                <StackPanel>
                    <!-- Official-looking header -->
                    <Border Background="#12FFFFFF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="ДОГОВОР № SAIL-2026/ROBUX" FontFamily="{StaticResource AppFont}"
                                       FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="SAIL PROJECT · bito 0.0.0.1 · 🇷🇺 🇺🇸" FontFamily="{StaticResource AppFont}"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="г. Интернет, «30» июня 2026 г." FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="🔏 Цифровая подпись: dolbaeb productions" FontFamily="{StaticResource AppFont}"
                                       FontSize="10" Foreground="{StaticResource AccentPurpleBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Funny illustration -->
                    <Grid Margin="0,0,0,20">
                        <Border CornerRadius="12" Height="100" ClipToBounds="True">
                            <Grid>
                                <Border Background="{StaticResource HeroGradient}" Opacity="0.3"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🤝💸🎮" FontSize="36" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Два человека. Один договор. Ноль robux на совести."
                                               FontFamily="{StaticResource AppFont}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="24">

                        <Run FontWeight="SemiBold">Сторона А</Run>
                        <Run> (далее — «Продавец аккаунта с огненным инвентарём»), с одной стороны, и</Run>
                        <LineBreak/>
                        <Run FontWeight="SemiBold">Сторона Б</Run>
                        <Run> (далее — «Человек, который хочет свои 15%»), с другой стороны,</Run>
                        <LineBreak/>
                        <Run>совместно именуемые «Люди, которые точно не пожалеют», заключили настоящий договор о нижеследующем:</Run>
                    </TextBlock>

                    <Separator Margin="0,16" Background="#18FFFFFF"/>

                    <!-- Articles -->
                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="26" Margin="0,0,0,8">

                        <Run FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}">Статья 1. Предмет договора</Run>
                        <LineBreak/>
                        <Run>1.1. Продавец обязуется продать аккаунт Roblox, а Сторона Б имеет право урвать </Run>
                        <Run FontWeight="Bold">15% (пятнадцать процентов)</Run>
                        <Run> от каждой продажи. Не 14%. Не «округлим до 10». Именно 15.</Run>
                        <LineBreak/>
                        <Run>1.2. Продажа включает, но не ограничивается: аккаунты с rare items, limited'ами, adopt me питомцами и тем самым скином, за который ты три года гриндил.</Run>
                    </TextBlock>

                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="26" Margin="0,12,0,8">

                        <Run FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}">Статья 2. Обязанности сторон</Run>
                        <LineBreak/>
                        <Run>2.1. Продавец обязуется:</Run>
                        <LineBreak/>
                        <Run>  • Не удалять друга из Roblox после сделки;</Run>
                        <LineBreak/>
                        <Run>  • Не говорить «я забыл про договор» — забыл, но 15% всё равно;</Run>
                        <LineBreak/>
                        <Run>  • Не тратить всю выручку на Robux Premium в первый же день.</Run>
                        <LineBreak/>
                        <Run>2.2. Сторона Б обязуется:</Run>
                        <LineBreak/>
                        <Run>  • Напоминать о 15% максимально тактично (1 раз в 5 минут);</Run>
                        <LineBreak/>
                        <Run>  • Хранить этот договор вечно и показывать друзьям;</Run>
                        <LineBreak/>
                        <Run>  • Смеяться, но не слишком громко.</Run>
                    </TextBlock>

                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="26" Margin="0,12,0,8">

                        <Run FontWeight="Bold" Foreground="{StaticResource AccentPinkBrush}">Статья 3. Расчёт 15%</Run>
                        <LineBreak/>
                        <Run>3.1. Формула: (Цена продажи × 0.15) = Сколько ты мне должен.</Run>
                        <LineBreak/>
                        <Run>3.2. Продали за 1000₽? → 150₽ мне. Продали за 10000₽? → 1500₽ мне. Математика не обсуждается.</Run>
                        <LineBreak/>
                        <Run>3.2.1. Округление — всегда в мою пользу. Всегда. 🎯</Run>
                    </TextBlock>

                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="26" Margin="0,12,0,8">

                        <Run FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}">Статья 4. Форс-мажор</Run>
                        <LineBreak/>
                        <Run>4.1. Бан аккаунта Roblox — не освобождает от 15% с других продаж.</Run>
                        <LineBreak/>
                        <Run>4.2. «У меня нет денег» — не форс-мажор, а статья 5.</Run>
                        <LineBreak/>
                        <Run>4.3. Потеря пароля — твоя проблема, 15% — моя.</Run>
                    </TextBlock>

                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="26" Margin="0,12,0,8">

                        <Run FontWeight="Bold" Foreground="#FFFF9F0A">Статья 5. Штрафы</Run>
                        <LineBreak/>
                        <Run>5.1. За каждый день просрочки выплаты 15% — +1% сверху. День за днём. Как проценты по кредиту, только смешнее.</Run>
                        <LineBreak/>
                        <Run>5.2. Попытка «передоговориться» — штраф в виде публичного показа этого договора в галерее мемов.</Run>
                    </TextBlock>

                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="26" Margin="0,12,0,8">

                        <Run FontWeight="Bold">Статья 6. Заключительные положения</Run>
                        <LineBreak/>
                        <Run>6.1. Договор вступает в силу с момента нажатия кнопки «Подписать и обдриться от смеха».</Run>
                        <LineBreak/>
                        <Run>6.2. Договор действует вечно, до тепловой смерти Вселенной и дольше.</Run>
                        <LineBreak/>
                        <Run>6.3. Споры решаются в чате Discord, арбитром выступает тот, кто первый скинет этот договор.</Run>
                    </TextBlock>

                    <Separator Margin="0,20" Background="#18FFFFFF"/>

                    <!-- Signature section -->
                    <TextBlock Text="Подписи сторон:" FontFamily="{StaticResource AppFont}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Сторона А (Продавец)" FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="PartyAName" Margin="0,8,0,0"
                                     Background="#12FFFFFF" Foreground="White"
                                     BorderBrush="#28FFFFFF" BorderThickness="1"
                                     Padding="12,10" FontFamily="{StaticResource AppFont}"
                                     FontSize="13" CaretBrush="White"
                                     Text="Введите имя продавца..."/>
                            <Border Height="60" Margin="0,12,0,0" CornerRadius="8"
                                    Background="#08FFFFFF" BorderBrush="#18FFFFFF"
                                    BorderThickness="1" Padding="8">
                                <TextBlock x:Name="PartyASignature" Text="✍️ (подпись появится после согласия)"
                                           FontFamily="Segoe Script, Comic Sans MS" FontSize="18"
                                           Foreground="#60FFFFFF" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Сторона Б (Получатель 15%)" FontFamily="{StaticResource AppFont}"
                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="PartyBName" Margin="0,8,0,0"
                                     Background="#12FFFFFF" Foreground="White"
                                     BorderBrush="#28FFFFFF" BorderThickness="1"
                                     Padding="12,10" FontFamily="{StaticResource AppFont}"
                                     FontSize="13" CaretBrush="White"
                                     Text="Введите имя получателя..."/>
                            <Border Height="60" Margin="0,12,0,0" CornerRadius="8"
                                    Background="#08FFFFFF" BorderBrush="#18FFFFFF"
                                    BorderThickness="1" Padding="8">
                                <TextBlock x:Name="PartyBSignature" Text="✍️ (подпись появится после согласия)"
                                           FontFamily="Segoe Script, Comic Sans MS" FontSize="18"
                                           Foreground="#60FFFFFF" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Checkboxes -->
                    <StackPanel Margin="0,24,0,0">
                        <CheckBox x:Name="AgreePercent" Margin="0,0,0,10"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource AppFont}" FontSize="13">
                            Я осознанно соглашаюсь отдавать 15% с каждой продажи аккаунта Roblox
                        </CheckBox>
                        <CheckBox x:Name="AgreeForever" Margin="0,0,0,10"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource AppFont}" FontSize="13">
                            Я понимаю, что «потом договоримся» — не работает
                        </CheckBox>
                        <CheckBox x:Name="AgreeLaugh" Margin="0,0,0,10"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource AppFont}" FontSize="13">
                            Я готов(а) обдриться от смеха, читая этот договор
                        </CheckBox>
                        <CheckBox x:Name="AgreeMemes"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  FontFamily="{StaticResource AppFont}" FontSize="13">
                            Я разрешаю использовать мой ник в галерее мемов при нарушении договора
                        </CheckBox>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Action bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="🏃 Отклонить (мини-игра)" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,12,0" Click="Reject_Click"/>
            <Button Content="🖨️ Распечатать" Style="{StaticResource SecondaryButton}"
                    Margin="0,0,12,0" Click="Print_Click"/>
            <Button x:Name="SignButton" Content="✅ Подписать и обдриться от смеха"
                    Style="{StaticResource PrimaryButton}" Click="Sign_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
