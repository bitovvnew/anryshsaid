<UserControl x:Class="SAIL.Views.FunZoneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border CornerRadius="20" Height="140" Margin="0,0,0,24" ClipToBounds="True">
                <Grid>
                    <Border Background="{StaticResource HeroGradient}" Opacity="0.9"/>
                    <StackPanel VerticalAlignment="Center" Margin="28,0">
                        <TextBlock Text="🎪 Зона приколов" FontFamily="{StaticResource AppFont}"
                                   FontSize="32" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Apple · Windows 11 · iOS 26 — но смешнее"
                                   FontFamily="{StaticResource AppFont}" FontSize="14"
                                   Foreground="#E0FFFFFF" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Columns="2" Margin="0,0,0,20">
                <Border Style="{StaticResource GlassCard}" Margin="0,0,10,16">
                    <StackPanel>
                        <TextBlock Text="🎲 Мем-рулетка" FontFamily="{StaticResource AppFont}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="QuoteText" Text="Нажми кнопку..."
                                   FontFamily="{StaticResource AppFont}" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" MinHeight="60" Margin="0,12,0,0"/>
                        <Button Content="🎰 Крутить!" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Margin="0,16,0,0" Click="SpinQuote_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource GlassCard}" Margin="10,0,0,16">
                    <StackPanel>
                        <TextBlock Text="💸 Генератор боли" FontFamily="{StaticResource AppFont}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="PainText" Text="???"
                                   FontFamily="{StaticResource AppFont}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentPinkBrush}" Margin="0,12,0,0"/>
                        <Button Content="😱 Сгенерировать" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Left" Margin="0,16,0,0" Click="GeneratePain_Click"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="📜 Стена позора (цитаты)" FontFamily="{StaticResource AppFont}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <ItemsControl x:Name="QuotesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,10" Padding="16">
                            <TextBlock Text="{Binding}" FontFamily="{StaticResource AppFont}" FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Style="{StaticResource GlassCard}" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="🏃 Мини-игра: Побег от 15%" FontFamily="{StaticResource AppFont}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Отклонил договор? Докажи что можешь сбежать от 15%!"
                               FontFamily="{StaticResource AppFont}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0"/>
                    <Button Content="🎮 Играть" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Margin="0,16,0,0" Click="PlayEscape_Click"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
